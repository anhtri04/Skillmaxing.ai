{
  "manifest_version": 3,
  "name": "Skillmaxing.ai",
  "version": "0.0.1",
  "description": "AI-powered skill tracking and enhancement",
  "action": {
    "default_title": "Open Skillmaxing"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_page": "src/options/index.html",
  "permissions": [
    "sidePanel",
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ]
}
